{
  "manifest_version": 3,
  "name": "Shiki Watch",
  "version": "1.4",
  "description": "The add-on adds the ability to watch on the Shikimori",

  "icons": {
    "128": "icons/logo128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "@shiki-watch.ch1ka",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "host_permissions": [
    "*://shikimori.one/*",
    "*://shiki.one/*",
    "*://shikimori.io/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "*://shikimori.one/*",
        "*://shiki.one/*",
        "*://shikimori.io/*"
      ],
      "js": ["./scripts/player.js"],
      "run_at": "document_start"
    }
  ]
}
